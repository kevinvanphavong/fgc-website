# Family Games Center — Site 2026/2027
# Copier en .env.local et remplir si nécessaire (rien de bloquant pour le dev frontend)

# Base URL du site (utile pour SEO, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend Symfony — base URL des appels API
# Dev local : http://127.0.0.1:8000/api (Symfony serve)
# Prod      : https://api.familygamescenter.fr/api
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# Stripe (clé publique pour le tunnel anniversaire — acompte 50€)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxx

# Lien de réservation externe (provisoire — pointe vers bowling-de-blois.fr)
# Sera retiré quand le tunnel résa interne sera en ligne.
NEXT_PUBLIC_RESERVATION_URL=https://www.bowling-de-blois.fr/

# Coordonnées (utilisées dans le footer)
NEXT_PUBLIC_PHONE=02 54 74 85 21
NEXT_PUBLIC_EMAIL=contact@familygamescenter.fr
NEXT_PUBLIC_ADDRESS_LINE1=25 rue Robert Nau
NEXT_PUBLIC_ADDRESS_LINE2=41000 Blois

# Analytics (à activer plus tard)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=familygamescenter.fr
