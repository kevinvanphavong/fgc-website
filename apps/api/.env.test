# Env vars chargées en APP_ENV=test (commitées : aucune fuite secret prod).
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# DB de test : pas de docker-compose en V1 (Kévin n'a pas d'env docker
# local). On utilise le Postgres local du Mac avec le user `kevinvanphavong`
# qui détient déjà fgc_dev. La conf `dbname_suffix: _test` (cf.
# config/packages/doctrine.yaml when@test) suffixe fgc_dev → fgc_dev_test.
# `.env.local` n'est PAS chargé en env=test, donc on duplique l'URL ici.
DATABASE_URL="postgresql://kevinvanphavong@127.0.0.1:5432/fgc_dev?serverVersion=15&charset=utf8"

# JWT keys dédiées env=test. Passphrase courte « test » : OK car env=test only,
# ces clés ne signent jamais en prod (cf. docs/GOTCHAS.md).
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private-test.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public-test.pem
JWT_PASSPHRASE=test

# Fixture TestUserFixture — credentials staff de test (cf. tests/Support/AuthenticatedClientTrait.php).
ADMIN_INITIAL_EMAIL=staff@test.fgc
ADMIN_INITIAL_PASSWORD=TestPassw0rd!
ADMIN_INITIAL_FIRST_NAME=Test
ADMIN_INITIAL_LAST_NAME=Staff
ADMIN_INITIAL_AVATAR_COLOR='linear-gradient(135deg,#FF2D87,#5E2DB8)'
