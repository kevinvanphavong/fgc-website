<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>FGC Admin — Connexion</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: system-ui, sans-serif; background: #160a3a; color: #fff4e0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: #1e1252; border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 400px; box-shadow: 0 4px 24px rgba(0,0,0,.4); }
        h1 { font-size: 1.5rem; margin-bottom: .5rem; text-align: center; }
        .subtitle { color: #b3a8d3; text-align: center; margin-bottom: 2rem; font-size: .9rem; }
        label { display: block; font-size: .85rem; margin-bottom: .3rem; color: #b3a8d3; }
        input { width: 100%; padding: .7rem .9rem; border: 1px solid #3a2d6b; border-radius: 8px; background: #120840; color: #fff4e0; font-size: 1rem; margin-bottom: 1.2rem; outline: none; }
        input:focus { border-color: #fbbf24; }
        button { width: 100%; padding: .75rem; background: #fbbf24; color: #160a3a; border: none; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; }
        button:hover { background: #f59e0b; }
        .error { background: #7f1d1d; color: #fca5a5; padding: .7rem 1rem; border-radius: 8px; margin-bottom: 1.2rem; font-size: .85rem; }
    </style>
</head>
<body>
<div class="card">
    <h1>Family Games Center</h1>
    <p class="subtitle">Administration du site</p>

    {% if error %}
        <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post">
        <label for="email">Email</label>
        <input type="email" id="email" name="_username" value="{{ last_username }}" required autofocus>

        <label for="password">Mot de passe</label>
        <input type="password" id="password" name="_password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit">Se connecter</button>
    </form>
</div>
</body>
</html>
