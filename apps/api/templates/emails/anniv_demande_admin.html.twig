<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Demande anniv — {{ reservation.reference }}</title>
</head>
<body style="margin:0;padding:24px;background:#160a3a;color:#fff4e0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
    <div style="max-width:560px;margin:0 auto;background:#3d1b6b;border-radius:18px;padding:32px;">
        <h1 style="font-size:22px;margin:0 0 8px;color:#ffd93d;">
            🎉 Nouvelle demande anniversaire
        </h1>
        <p style="margin:0 0 24px;color:#fff4e0;opacity:.85;">
            Référence <strong style="color:#ff2d87;">{{ reservation.reference }}</strong> ·
            Reçue le {{ reservation.createdAt|date('d/m/Y à H:i') }}
        </p>

        <div style="background:#160a3a;border-radius:14px;padding:20px;margin-bottom:16px;">
            <h2 style="font-size:14px;text-transform:uppercase;letter-spacing:.08em;color:#ffd93d;margin:0 0 12px;">La fête</h2>
            <p style="margin:6px 0;"><strong>Formule :</strong> {{ formule.icon }} {{ formule.name }} ({{ formule.duration }})</p>
            <p style="margin:6px 0;"><strong>Date :</strong> {{ reservation.eventDate|date('l d/m/Y') }}</p>
            <p style="margin:6px 0;"><strong>Créneau :</strong> {{ reservation.timeSlot }}</p>
            <p style="margin:6px 0;"><strong>Nombre d'enfants :</strong> {{ reservation.kidsCount }}</p>
            <p style="margin:6px 0;"><strong>Total estimé :</strong> {{ (totalCents / 100)|number_format(2, ',', ' ') }} €</p>
            {% if reservation.upsellVR %}
                <p style="margin:6px 0;color:#00e5ff;">🥽 <strong>Upsell VR coché</strong> à l'étape 3.</p>
            {% endif %}
        </div>

        <div style="background:#160a3a;border-radius:14px;padding:20px;margin-bottom:16px;">
            <h2 style="font-size:14px;text-transform:uppercase;letter-spacing:.08em;color:#ffd93d;margin:0 0 12px;">L'enfant</h2>
            <p style="margin:6px 0;"><strong>Prénom :</strong> {{ reservation.childName }}</p>
            <p style="margin:6px 0;"><strong>Âge fêté :</strong> {{ reservation.childAge }} ans</p>
            {% if reservation.cakeNote %}
                <p style="margin:6px 0;"><strong>Souhait gâteau :</strong> {{ reservation.cakeNote }}</p>
            {% endif %}
            {% if reservation.allergies %}
                <p style="margin:6px 0;color:#ff2d87;"><strong>Allergies / régimes :</strong> {{ reservation.allergies }}</p>
            {% endif %}
        </div>

        <div style="background:#160a3a;border-radius:14px;padding:20px;margin-bottom:16px;">
            <h2 style="font-size:14px;text-transform:uppercase;letter-spacing:.08em;color:#ffd93d;margin:0 0 12px;">Parent organisateur</h2>
            <p style="margin:6px 0;"><strong>{{ reservation.parentFirstName }} {{ reservation.parentLastName }}</strong></p>
            <p style="margin:6px 0;">📧 <a href="mailto:{{ reservation.parentEmail }}" style="color:#00e5ff;">{{ reservation.parentEmail }}</a></p>
            <p style="margin:6px 0;">📱 <a href="tel:{{ reservation.parentPhone|replace({' ': ''}) }}" style="color:#00e5ff;">{{ reservation.parentPhone }}</a></p>
            {% if reservation.source %}
                <p style="margin:6px 0;"><strong>Source :</strong> {{ reservation.source }}</p>
            {% endif %}
            {% if reservation.message %}
                <p style="margin:12px 0 0;"><strong>Message :</strong></p>
                <p style="margin:6px 0;padding:12px;background:#3d1b6b;border-radius:8px;">{{ reservation.message }}</p>
            {% endif %}
            <p style="margin:12px 0 0;font-size:13px;opacity:.7;">
                Newsletter : {{ reservation.acceptNewsletter ? '✅ oui' : '❌ non' }}
            </p>
        </div>

        <div style="text-align:center;margin-top:24px;padding-top:24px;border-top:1px solid rgba(255,244,224,.1);">
            <p style="margin:0 0 16px;opacity:.85;">📞 Rappel sous 24h pour confirmer la date + organiser l'acompte.</p>
            <p style="margin:0;font-size:12px;opacity:.6;">
                Lien admin (futur, PR5) :
                <a href="https://familygamescenter.fr/admin/reservations/{{ reservation.reference }}" style="color:#ffd93d;">
                    Marquer comme contactée
                </a>
            </p>
        </div>
    </div>
</body>
</html>
