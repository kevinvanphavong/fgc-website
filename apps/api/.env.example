# Family Games Center — Backend Symfony
# Copier en .env.local et remplir avec les valeurs réelles.

APP_ENV=dev
APP_SECRET=change-me-32-chars-random

# Base de données (Postgres recommandé, MariaDB possible si Kévin préfère)
DATABASE_URL="postgresql://fgc:fgc@127.0.0.1:5432/fgc?serverVersion=16&charset=utf8"

# Mailer — Brevo en prod (ou SMTP OVH/Sendgrid)
MAILER_DSN=smtp://localhost:1025
MAILER_FROM=contact@familygamescenter.fr
MAILER_REPLY_TO=contact@familygamescenter.fr

# JWT (clés générées par lexik:jwt:generate-keypair)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me

# Stripe (acompte 50€ tunnel anniversaire)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_DEPOSIT_AMOUNT_CENTS=5000

# CORS (front Next.js — dev local + prod + previews Vercel)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$|^https://familygamescenter\.fr$|^https://.*\.vercel\.app$'
